{
  "name": "sigil",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run generate:maps && npm run dev -w @sigil/client",
    "build": "npm run build -ws",
    "typecheck": "npm run typecheck -w @sigil/client",
    "generate:maps": "npm run generate:maps -w @sigil/world",
    "qa:smoke": "node qa/run-smoke.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "playwright": "^1.52.0"
  }
}
